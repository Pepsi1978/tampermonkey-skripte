{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "95",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "CLAUDE_CODE_SESSIONEND_HOOKS_TIMEOUT_MS": "10000"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "NotebookEdit",
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__claude_ai_Gmail__gmail_create_draft",
      "mcp__claude_ai_Gmail__gmail_get_profile",
      "mcp__claude_ai_Gmail__gmail_list_drafts",
      "mcp__claude_ai_Gmail__gmail_list_labels",
      "mcp__claude_ai_Gmail__gmail_read_message",
      "mcp__claude_ai_Gmail__gmail_read_thread",
      "mcp__claude_ai_Gmail__gmail_search_messages",
      "mcp__claude_ai_Google_Calendar__gcal_create_event",
      "mcp__claude_ai_Google_Calendar__gcal_delete_event",
      "mcp__claude_ai_Google_Calendar__gcal_find_meeting_times",
      "mcp__claude_ai_Google_Calendar__gcal_find_my_free_time",
      "mcp__claude_ai_Google_Calendar__gcal_get_event",
      "mcp__claude_ai_Google_Calendar__gcal_list_calendars",
      "mcp__claude_ai_Google_Calendar__gcal_list_events",
      "mcp__claude_ai_Google_Calendar__gcal_respond_to_event",
      "mcp__claude_ai_Google_Calendar__gcal_update_event",
      "mcp__claude_ai_PubMed__convert_article_ids",
      "mcp__claude_ai_PubMed__find_related_articles",
      "mcp__claude_ai_PubMed__get_article_metadata",
      "mcp__claude_ai_PubMed__get_copyright_status",
      "mcp__claude_ai_PubMed__get_full_text_article",
      "mcp__claude_ai_PubMed__lookup_article_by_citation",
      "mcp__claude_ai_PubMed__search_articles",
      "mcp__claude_ai_Scholar_Gateway__semanticSearch"
    ]
  },
  "model": "claude-opus-4-6",
  "effortLevel": "high",
  "enableAllProjectMcpServers": true,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/data/data/com.termux/files/home/.claude/hooks/notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/data/data/com.termux/files/home/.claude/hooks/disk-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": {
          "toolName": "Edit|Write"
        },
        "hooks": [
          {
            "type": "command",
            "command": "/data/data/com.termux/files/home/.claude/hooks/auto-format-termux.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/data/data/com.termux/files/home/.claude/hooks/session-cleanup.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
