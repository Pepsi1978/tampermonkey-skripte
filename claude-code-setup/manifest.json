{
  "description": "Claude Code Setup-Manifest - Installiert alle Plugins, Skills, Dev-Tools, MCP-Server und Settings auf einem neuen Rechner",
  "version": "2.2.0",
  "author": "Pepsi1978",
  "github_user": "Pepsi1978",
  "repo": "https://github.com/Pepsi1978/proggs",

  "dev_tools": {
    "required": ["node", "git", "gh"],
    "recommended": {
      "bun": {
        "macos": "brew install oven-sh/bun/bun",
        "windows": "winget install Oven-sh.Bun"
      },
      "deno": {
        "macos": "brew install deno",
        "windows": "winget install DenoLand.Deno"
      },
      "rust": {
        "macos": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y",
        "windows": "winget install Rustlang.Rustup"
      },
      "docker": {
        "macos": "brew install --cask docker",
        "windows": "winget install Docker.DockerDesktop"
      },
      "dotnet": {
        "macos": "brew install dotnet-sdk",
        "windows": "winget install Microsoft.DotNet.SDK.10"
      }
    }
  },

  "plugins": {
    "claude-plugins-official": [
      "swift-lsp",
      "typescript-lsp",
      "csharp-lsp",
      "clangd-lsp",
      "rust-analyzer-lsp",
      "gopls-lsp",
      "jdtls-lsp",
      "kotlin-lsp",
      "lua-lsp",
      "php-lsp",
      "pyright-lsp",
      "ruby-lsp",
      "superpowers",
      "frontend-design",
      "context7",
      "github",
      "feature-dev",
      "code-simplifier",
      "commit-commands",
      "security-guidance",
      "claude-md-management",
      "pr-review-toolkit",
      "claude-code-setup",
      "hookify",
      "playground",
      "ralph-loop",
      "code-review",
      "playwright",
      "coderabbit",
      "explanatory-output-style",
      "skill-creator",
      "plugin-dev",
      "agent-sdk-dev",
      "serena",
      "slack",
      "linear",
      "firebase",
      "supabase",
      "stripe",
      "asana",
      "gitlab",
      "greptile",
      "laravel-boost"
    ],
    "superpowers-marketplace": [
      "episodic-memory",
      "double-shot-latte",
      "superpowers-chrome",
      "claude-session-driver",
      "superpowers-lab",
      "superpowers-developing-for-claude-code",
      "elements-of-style"
    ]
  },

  "mcp_servers": {
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  },

  "security_tools": {
    "parry": {
      "install": {
        "macos": "~/.cargo/bin/cargo install --git https://github.com/vaporif/parry parry-ai",
        "windows": "%USERPROFILE%\\.cargo\\bin\\cargo install --git https://github.com/vaporif/parry parry-ai"
      },
      "hooks": {
        "UserPromptSubmit": {
          "command": "parry hook",
          "timeout": 2
        }
      }
    },
    "cargo-audit": {
      "install": {
        "macos": "cargo install cargo-audit",
        "windows": "cargo install cargo-audit"
      },
      "description": "Scans Rust crate dependencies for known CVEs (run: cargo audit)"
    }
  },

  "extra_marketplaces": {
    "superpowers-marketplace": {
      "source": "github",
      "repo": "obra/superpowers-marketplace",
      "autoUpdate": true
    }
  },

  "custom_skills": [
    "auto-verify-iterate",
    "cross-platform",
    "self-improve",
    "tampermonkey-version",
    "tool-check",
    "undo-changes"
  ],

  "custom_agents": [
    "architect",
    "code-reviewer",
    "debugger",
    "optimizer",
    "researcher",
    "tester",
    "ui-polisher",
    "coder",
    "batch-reviewer"
  ],

  "settings": {
    "effortLevel": "medium",
    "env": {
      "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
    },
    "permissions": [
      "Bash", "Read", "Edit", "Write", "Glob", "Grep",
      "WebFetch", "WebSearch", "Agent", "NotebookEdit"
    ]
  }
}
