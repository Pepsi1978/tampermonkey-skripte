{
  "_comment": "Add this 'hooks' section to settings.json on Windows. Add Parry hook only after installing parry.exe.",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.claude\\hooks\\notify.ps1",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File %USERPROFILE%\\.claude\\hooks\\auto-format.ps1",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
