				"claude-code-setup/bridges/gemini-delta-bridge.json"
			],
			"state_file": "claude-code-setup/state/gemini-delta-state.json",
			"state_scope": "gemini-environment-only",
			"trigger_phrases": [
				"starte bitte die Bruecke zu Gemini CLI",
				"was wurde bei Gemini CLI erneuert",
				"welche Verbesserungen gibt es bei Gemini CLI",
				"was kann Claude Code von Gemini CLI lernen",
				"hol dir die neuesten Informationen von Gemini"
			],
			"audit_title": "Gemini CLI Delta Audit",
			"no_delta_message": "Keine neuen portablen Gemini-Setup-Deltas seit dem Basisstand."
