<Window x:Class="TerminalVoiceOverlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TerminalVoiceOverlay"
        Width="72" Height="432"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Circle button style: 40x40, CornerRadius=20 -->
        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mic button style: 52x52, CornerRadius=10 (rounded square) -->
        <Style x:Key="MicButton" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Panel background: pill shape, semi-transparent dark -->
    <Border CornerRadius="36"
            Background="#B31E1E1E"
            Width="72" Height="432">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,16">

            <!-- Mic Button (main mic — rounded square) — top -->
            <Button x:Name="MicButton"
                    Style="{StaticResource MicButton}"
                    Click="BtnMic_Click"
                    ToolTip="Start / stop recording">
                <Viewbox Width="22" Height="22">
                    <Path Fill="White" Data="M12,14 C13.66,14 15,12.66 15,11 L15,5 C15,3.34 13.66,2 12,2 C10.34,2 9,3.34 9,5 L9,11 C9,12.66 10.34,14 12,14 Z M17.3,11 C17.3,14 14.76,16.1 12,16.1 C9.24,16.1 6.7,14 6.7,11 L5,11 C5,14.41 7.72,17.23 11,17.72 L11,21 L13,21 L13,17.72 C16.28,17.23 19,14.41 19,11 L17.3,11 Z"/>
                </Viewbox>
            </Button>

            <!-- BTW Button (BTW mic — rounded square, blue tint set in code-behind) -->
            <Button x:Name="BtwButton"
                    Style="{StaticResource MicButton}"
                    Margin="0,8,0,0"
                    Click="BtnBtw_Click"
                    ToolTip="BTW voice input">
                <Viewbox Width="22" Height="22">
                    <Path Fill="White" Data="M12,14 C13.66,14 15,12.66 15,11 L15,5 C15,3.34 13.66,2 12,2 C10.34,2 9,3.34 9,5 L9,11 C9,12.66 10.34,14 12,14 Z M17.3,11 C17.3,14 14.76,16.1 12,16.1 C9.24,16.1 6.7,14 6.7,11 L5,11 C5,14.41 7.72,17.23 11,17.72 L11,21 L13,21 L13,17.72 C16.28,17.23 19,14.41 19,11 L17.3,11 Z"/>
                </Viewbox>
            </Button>

            <!-- G Button (Gemini toggle) -->
            <Button x:Name="GButton"
                    Style="{StaticResource CircleButton}"
                    Margin="0,8,0,0"
                    Click="BtnGemini_Click"
                    ToolTip="Toggle Gemini">
                <TextBlock Text="G" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

            <!-- W Button (Whisper undo) -->
            <Button x:Name="WButton"
                    Style="{StaticResource CircleButton}"
                    Margin="0,8,0,0"
                    Click="BtnWhisperUndo_Click"
                    ToolTip="Replace with raw Whisper text">
                <TextBlock Text="W" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

            <!-- X Button (clear line) -->
            <Button x:Name="XButton"
                    Style="{StaticResource CircleButton}"
                    Margin="0,8,0,0"
                    Click="BtnClear_Click"
                    ToolTip="Clear line">
                <TextBlock Text="X" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

            <!-- Copy Button (copy selected text) -->
            <Button x:Name="CopyButton"
                    Style="{StaticResource CircleButton}"
                    Margin="0,8,0,0"
                    Click="BtnCopy_Click"
                    ToolTip="Copy selected text">
                <Viewbox Width="18" Height="18">
                    <Path Fill="White" Data="M16,1H4C2.9,1,2,1.9,2,3v14h2V3h12V1z M19,5H8C6.9,5,6,5.9,6,7v14c0,1.1,0.9,2,2,2h11c1.1,0,2-0.9,2-2V7C21,5.9,20.1,5,19,5z M19,21H8V7h11V21z"/>
                </Viewbox>
            </Button>

            <!-- Paste Button (paste clipboard into command line) -->
            <Button x:Name="PasteButton"
                    Style="{StaticResource CircleButton}"
                    Margin="0,8,0,0"
                    Click="BtnPaste_Click"
                    ToolTip="Paste into command line">
                <Viewbox Width="18" Height="18">
                    <Path Fill="White" Data="M19,2h-4.18C14.4,0.84,13.3,0,12,0S9.6,0.84,9.18,2H5C3.9,2,3,2.9,3,4v16c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V4C21,2.9,20.1,2,19,2z M12,2c0.55,0,1,0.45,1,1s-0.45,1-1,1s-1-0.45-1-1S11.45,2,12,2z M19,20H5V4h2v3h10V4h2V20z"/>
                </Viewbox>
            </Button>

            <!-- Enter Button (auto-enter toggle) — bottom -->
            <Button x:Name="EnterButton"
                    Style="{StaticResource CircleButton}"
                    Margin="0,8,0,0"
                    Click="BtnAutoEnter_Click"
                    ToolTip="Toggle auto-enter">
                <TextBlock Text="&#x23CE;" FontSize="18" Foreground="White"/>
            </Button>

        </StackPanel>
    </Border>
</Window>
