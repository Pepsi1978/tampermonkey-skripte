# Groq (Whisper Speech-to-Text)
# API-Key von https://console.groq.com/
GROQ_API_KEY=
WHISPER_MODEL=whisper-large-v3
WHISPER_LANG=de
WHISPER_URL=https://api.groq.com/openai/v1/audio/transcriptions

# Gemini (Textverbesserung)
# API-Key von https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Thinking-Level nur fuer Gemini 3.x (LOW/MEDIUM/HIGH)
GEMINI_THINKING_LEVEL=MEDIUM

# Audio
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Terminal-Prozesserkennung (kommagetrennt, Gross-/Kleinschreibung egal)
TERMINAL_PROCESS_NAMES=WindowsTerminal,pwsh,powershell,cmd,mintty
