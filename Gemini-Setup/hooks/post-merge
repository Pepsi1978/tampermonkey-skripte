#!/bin/bash
# Post-merge hook (Gemini): Restore platform-specific .mcp.json after git pull
# Prevents cross-platform MCP config corruption (macOS paths on Windows or vice versa)
#
# Installation: cp Gemini-Setup/hooks/post-merge .git/hooks/post-merge && chmod +x .git/hooks/post-merge

REPO_DIR="$(git rev-parse --show-toplevel)"
MCP_FILE="$REPO_DIR/.mcp.json"

# Detect platform and select correct reference file
if [[ "$OS" == "Windows_NT" ]] || [[ "$(uname -s)" == MINGW* ]] || [[ "$(uname -s)" == MSYS* ]]; then
    REFERENCE="$REPO_DIR/Gemini-Setup/mcp-windows.json"
    PLATFORM="Windows"
elif [[ "$(uname -s)" == "Darwin" ]]; then
    REFERENCE="$REPO_DIR/Gemini-Setup/mcp-macos.json"
    PLATFORM="macOS"
else
    # Linux/other — no reference file, skip silently
    exit 0
fi

# Only restore if the reference file exists
if [[ ! -f "$REFERENCE" ]]; then
    echo "[post-merge] WARNING: Reference file missing: $REFERENCE"
    exit 0
fi

# Check if .mcp.json was changed in the merge
# ORIG_HEAD is the commit before the merge
if git diff-tree -r --name-only ORIG_HEAD HEAD 2>/dev/null | grep -q '\.mcp\.json'; then
    # .mcp.json was changed by the pull — restore platform-specific version
    cp "$REFERENCE" "$MCP_FILE"
    echo "[post-merge] Restored .mcp.json for $PLATFORM (was overwritten by pull)"
else
    # .mcp.json not changed — no action needed
    :
fi

exit 0
