{
	"version": 1,
	"bridge_name": "codex-delta",
	"source_label": "Codex CLI",
	"language": "de",
	"tracked_paths": ["codex-setup/**", "AGENTS.md"],
	"target_scope": "setup-and-programming-environment-only",
	"include_fixed_errors": true,
	"include_bugfix_logic": true,
	"include_implemented_intelligence_suggestions": true,
	"read_only_sources": [
		"codex-setup/**",
		"codex-setup/state/environment-fixes.json",
		"codex-setup/agent-memory/shared/MEMORY.md",
		"codex-setup/bridges/bridge-registry.json",
		"codex-setup/state/implemented-intelligence-suggestions.json",
		"AGENTS.md"
	],
	"classifications": ["ADD", "ADAPT", "REPLACE"],
	"proposal_only": true,
	"replacement_requires_confirmation": true,
	"additive_bias": true,
	"report_groups": [
		{ "code": "A", "title": "Regeln und Prompts" },
		{ "code": "B", "title": "Agents, Skills und Arbeitsprozesse" },
		{ "code": "C", "title": "Skripte, Hooks und Validierung" },
		{ "code": "D", "title": "Runtime und Konfiguration" },
		{ "code": "E", "title": "Fehlerfixes aus environment-fixes.json" }
	],
	"state_file": "Gemini-Setup/state/codex-delta-state.json",
	"spec_file": "Gemini-Setup/bridges/codex-delta-bridge.md",
	"bridge_registry": "Gemini-Setup/bridges/bridge-registry.json",
	"trigger_phrases": [
		"starte die Bruecke zu Codex CLI",
		"was hat Codex CLI verbessert",
		"welche Verbesserungen gibt es bei Codex",
		"welche Fehler hat Codex gefixt",
		"Codex-Delta pruefen",
		"synchronisiere mit Codex"
	]
}
