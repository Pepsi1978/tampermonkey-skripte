{
	"version": 1,
	"bridge_name": "environment-fix-exchange",
	"source_label": "CLI Environment Fixes",
	"language": "de",
	"scope": "programming-environment-only",
	"entry_schema": [
		"id",
		"source_cli",
		"category",
		"summary",
		"context_for_other_clis",
		"symptom_before_fix",
		"root_cause",
		"what_was_fixed",
		"why_it_was_fixed",
		"exact_error_text",
		"root_cause_why_chain",
		"related_error_sources_checked",
		"wrong_pattern_example",
		"right_pattern_example",
		"avoidance_rule",
		"resilience_summary",
		"fix_induced_failure_review",
		"verification",
		"portability_notes",
		"portable_to",
		"artifacts",
		"created_at",
		"status"
	],
	"requires_full_context": true,
	"requires_resilient_bugfix_fields": true,
	"write_scope": ["Gemini-Setup/ only"],
	"read_only_consumers": ["Claude Code", "Codex CLI"],
	"peer_fix_databases": {
		"codex": "codex-setup/state/environment-fixes.json",
		"claude_code": "claude-code-setup/environment-fixes.md"
	},
	"own_fix_database": "Gemini-Setup/agent-memory/shared/MEMORY.md",
	"bridge_registry": "Gemini-Setup/bridges/bridge-registry.json"
}
