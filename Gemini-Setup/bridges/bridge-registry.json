{
	"version": 2,
	"registry_name": "gemini-bridge-registry",
	"registry_path": "Gemini-Setup/bridges/bridge-registry.json",
	"global_policies": {
		"proposal_only": true,
		"replace_requires_confirmation": true,
		"foreign_sources_read_only": true,
		"implemented_intelligence_must_be_resilient": true
	},
	"self_registration": {
		"Gemini CLI": {
			"repo_path": "Gemini-Setup/bridges/bridge-registry.json",
			"local_path": "C:\\Users\\barwa\\GeminiCLI/Gemini-Setup/bridges/bridge-registry.json",
			"write_policy": "read-write-own-workspace",
			"status": "active"
		}
	},
	"bridges": {
		"claude-code-delta": {
			"id": "claude-code-delta",
			"spec": "Gemini-Setup/bridges/claude-code-delta-bridge.md",
			"state": "Gemini-Setup/state/claude-code-delta-state.json",
			"sources": ["claude-code-setup/**", "CLAUDE.md"],
			"description": "Scannt Claude Code Setup auf neue Regeln, Agents, Skills, Hooks, Fixes",
			"trigger_phrases": [
				"starte die Bruecke zu Claude Code",
				"was hat Claude Code verbessert",
				"synchronisiere mit Claude Code"
			]
		},
		"codex-delta": {
			"id": "codex-delta",
			"spec": "Gemini-Setup/bridges/codex-delta-bridge.md",
			"state": "Gemini-Setup/state/codex-delta-state.json",
			"sources": ["codex-setup/**", "AGENTS.md"],
			"description": "Scannt Codex Setup auf neue Regeln, Skills, Fixes, Bridge-Updates",
			"trigger_phrases": [
				"starte die Bruecke zu Codex",
				"was hat Codex verbessert",
				"synchronisiere mit Codex"
			]
		},
		"environment-fix-exchange": {
			"id": "environment-fix-exchange",
			"spec": "Gemini-Setup/bridges/environment-fix-exchange-bridge.md",
			"state": "Gemini-Setup/state/environment-fix-exchange-state.json",
			"description": "Plattformuebergreifender Austausch von Umwelt-Fehlern und Fixes"
		},
		"intelligence-suggestion-exchange": {
			"id": "intelligence-suggestion-exchange",
			"spec": "Gemini-Setup/bridges/intelligence-suggestion-exchange-bridge.md",
			"state": "Gemini-Setup/state/intelligence-suggestion-exchange-state.json",
			"description": "Austausch von bereits umgesetzten Intelligenz-Vorschlaegen"
		}
	},
	"peer_registries": {
		"Codex": {
			"registry_path": "codex-setup/bridges/bridge-registry.json",
			"write_policy": "read-only-from-gemini"
		},
		"Claude Code": {
			"registry_path": "claude-code-setup/bridges/bridge-registry.json",
			"write_policy": "read-only-from-gemini",
			"status": "registered"
		}
	},
	"ledger_addresses": {
		"gemini_fixes": "Gemini-Setup/state/environment-fixes.json",
		"gemini_suggestions": "Gemini-Setup/state/implemented-intelligence-suggestions.json",
		"gemini_rule_archive": "Gemini-Setup/agent-memory/archive/rules/",
		"codex_fixes": "codex-setup/state/environment-fixes.json",
		"codex_suggestions": "codex-setup/state/implemented-intelligence-suggestions.json",
		"claude_code_fixes": "claude-code-setup/state/environment-fixes.json",
		"claude_code_suggestions": "claude-code-setup/state/implemented-intelligence-suggestions.json"
	},
	"shared_infrastructure": {
		"semantic_search": {
			"setup_guide": "claude-code-setup/SETUP-SEMANTIC-SEARCH-UNIVERSAL.md",
			"github_url": "https://github.com/Pepsi1978/proggs/blob/main/claude-code-setup/SETUP-SEMANTIC-SEARCH-UNIVERSAL.md",
			"server_source": "mcp-code-search/src/index.ts",
			"reindex_script": "mcp-code-search/src/reindex.ts",
			"description": "Lokale semantische Code-Suche via Ollama + nomic-embed-text."
		},
		"directives": {
			"directive_1": "Gemini-Setup/bridges/directive-1-superintelligence-universal.md",
			"directive_2": "Gemini-Setup/bridges/directive-2-self-observation-universal.md",
			"directive_3": "claude-code-setup/bridges/directive-3-resilient-bugfixing-universal.md",
			"description": "Die 3 Haupt-Direktiven in CLI-neutralem Format."
		}
	}
}
