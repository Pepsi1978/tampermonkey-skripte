{
	"version": 1,
	"bridge_name": "implemented-intelligence-suggestion-exchange",
	"source_label": "Implemented Intelligence Suggestions",
	"language": "de",
	"scope": "programming-environment-only",
	"proposal_prefix": "Intelligenz-Vorschlag:",
	"entry_schema": [
		"id",
		"source_cli",
		"summary",
		"proposal_text",
		"context_for_other_clis",
		"why_it_was_suggested",
		"why_it_was_implemented",
		"how_it_was_implemented",
		"bridge_value",
		"adoption_guidance",
		"resilience_summary",
		"future_failure_review",
		"portable_to",
		"artifacts",
		"created_at",
		"status"
	],
	"requires_full_context": true,
	"requires_resilience_fields": true,
	"own_ledger": "Gemini-Setup/state/implemented-intelligence-suggestions.json",
	"peer_ledgers": {
		"codex": "codex-setup/state/implemented-intelligence-suggestions.json",
		"claude_code": "claude-code-setup/state/implemented-intelligence-suggestions.json"
	},
	"write_scope": ["Gemini-Setup/ only"],
	"read_only_consumers": ["Claude Code", "Codex CLI"],
	"bridge_registry": "Gemini-Setup/bridges/bridge-registry.json"
}
