        "repo_path": "claude-code-setup/bridges/bridge-registry.json",
        "github_url": "https://github.com/Pepsi1978/proggs/blob/main/claude-code-setup/bridges/bridge-registry.json",
        "status": "awaiting-foreign-registration"
      },
      "Gemini CLI": {
        "repo_path": "Gemini-Setup/bridges/bridge-registry.json",
        "local_path": "%USERPROFILE%/GeminiCLI/bridges/bridge-registry.json",
