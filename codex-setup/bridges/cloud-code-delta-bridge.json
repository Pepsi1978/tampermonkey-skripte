{
  "version": 1,
  "bridge_name": "cloud-code-delta",
  "source_label": "Claude Code",
  "source_resolved_as": "Claude Code",
  "language": "de",
  "tracked_paths": [
    "CLAUDE.md",
    "claude-code-setup/**"
  ],
  "target_scope": "setup-and-programming-environment-only",
  "include_fixed_errors": true,
  "include_bugfix_logic": true,
  "include_implemented_intelligence_suggestions": true,
  "read_only_sources": [
    "CLAUDE.md",
    "claude-code-setup/**",
    "claude-code-setup/state/implemented-intelligence-suggestions.json"
  ],
  "classifications": [
    "ADD",
    "ADAPT",
    "REPLACE"
  ],
  "proposal_only": true,
  "replacement_requires_confirmation": true,
  "additive_bias": true,
  "report_groups": [
    {
      "code": "A",
      "title": "Regeln und Prompts"
    },
    {
      "code": "B",
      "title": "Agenten, Skills und Arbeitsprozesse"
    },
    {
      "code": "C",
      "title": "Skripte, Hooks und Validierung"
    },
    {
      "code": "D",
      "title": "Runtime und Konfiguration"
    }
  ],
  "trigger_phrases": [
    "hol dir die neuesten Informationen von Claude Code",
    "Starte bitte die Bruecke zu Claude Code",
    "was wurde bei Claude Code erneuert",
    "welche Verbesserungen gibt es bei Claude Code",
    "welche Regeln sind dort neuer",
    "welche Agenten oder Arbeitsprozesse sind dort neuer",
    "welche Fehler wurden bei Claude Code gefixt",
    "welche robuste Fixlogik gibt es bei Claude Code",
    "was davon ist fuer Codex sinnvoll",
    "schau im Codex Setup Ordner nach dieser Bruecke",
    "baue diese Bruecke auch fuer Gemini CLI"
  ],
  "reference_implementation": [
    "codex-setup/scripts/audit-claude-delta.mjs",
    "codex-setup/scripts/audit-claude-delta.sh",
    "codex-setup/scripts/audit-claude-delta.ps1"
  ],
  "bridge_registry": {
    "registry_path": "codex-setup/bridges/bridge-registry.json",
    "registry_github_url": "https://github.com/Pepsi1978/proggs/blob/main/codex-setup/bridges/bridge-registry.json",
    "bridge_id": "cloud-code-delta",
    "peer_expected_registries": {
