  "peer_adoption_tasks": [
    "Claude Code und Gemini CLI sollen dieselbe Registry-Dateiart im eigenen Setup anlegen.",
    "Jede Fremd-Bridge soll ihre genaue Registry-Adresse und ihre Ledger-Adressen darin veroeffentlichen.",
    "Jede Fremd-CLI soll zusaetzlich eigene Bootstrap-Skripte fuer frische Rechner anlegen und ihre Adressen sowohl in der Registry als auch in der Delta-Bruecke veroeffentlichen.",
    "Jede Fremd-CLI soll zusaetzlich einen registry-getriebenen Bootstrap-Report anlegen, der Bootstrap-, Ledger- und Bridge-Adressen gesammelt ausgibt.",
    "Die Universal Mirror Bridge soll als Export/Import-Pfad mit gemeinsamem Mirror-Ledger in allen CLIs veroeffentlicht werden.",
    "Fremde Registries bleiben fuer Codex strikt read-only."
  ],
  "bridges": {
    "cloud-code-delta": {
      "bridge_files": [
        "codex-setup/bridges/cloud-code-delta-bridge.md",
        "codex-setup/bridges/cloud-code-delta-bridge.json"
      ],
      "audit_title": "Claude Code Delta Audit",
      "state_scope": "claude-environment-only",
      "state_file": "codex-setup/state/claude-delta-state.json",
      "source_label": "Claude Code",
      "audit_git_paths": [
        "CLAUDE.md",
        "claude-code-setup"
      ],
      "source_paths": [
        "CLAUDE.md",
        "claude-code-setup/**",
        "claude-code-setup/state/implemented-intelligence-suggestions.json"
      ],
      "no_delta_message": "Keine neuen portablen Cloud-Code-Setup-Deltas seit dem Basisstand.",
      "trigger_phrases": [
        "hol dir die neuesten Informationen von Claude Code",
        "Starte bitte die Bruecke zu Claude Code",
        "was wurde bei Claude Code erneuert",
        "welche Verbesserungen gibt es bei Claude Code"
      ]
    },
