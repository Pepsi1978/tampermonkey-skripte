        "codex-setup/bridges/environment-fix-exchange-bridge.md",
        "codex-setup/bridges/environment-fix-exchange-bridge.json"
      ],
      "state_file": "codex-setup/state/environment-fixes.json",
      "source_label": "CLI Environment Fixes",
