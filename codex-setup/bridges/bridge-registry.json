      "write_policy": "read-only-from-codex",
      "status": "awaiting-foreign-registration"
    },
    "Gemini CLI": {
      "expected_repo_path": "Gemini-Setup/bridges/bridge-registry.json",
      "expected_local_path": "%USERPROFILE%/GeminiCLI/bridges/bridge-registry.json",
      "expected_github_url": "https://github.com/Pepsi1978/proggs/blob/main/Gemini-Setup/bridges/bridge-registry.json",
