<Window x:Class="ClaudeVoiceOverlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClaudeVoiceOverlay"
        Width="56" Height="256"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Round button style -->
        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="BtnEllipse"
                                     Fill="{TemplateBinding Background}"
                                     Width="{TemplateBinding Width}"
                                     Height="{TemplateBinding Height}"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Panel background: rounded rect, semi-transparent black -->
    <Border CornerRadius="28"
            Background="#B3000000"
            Padding="8">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <!-- X Button (clear input) -->
            <Button x:Name="BtnClear"
                    Style="{StaticResource RoundButton}"
                    Background="#2D2D2D"
                    Click="BtnClear_Click"
                    ToolTip="Eingabe loeschen">
                <TextBlock Text="X" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

            <!-- Mic Button -->
            <Button x:Name="BtnMic"
                    Style="{StaticResource RoundButton}"
                    Background="#2D2D2D"
                    Margin="0,8,0,0"
                    Click="BtnMic_Click"
                    ToolTip="Aufnahme starten/stoppen">
                <TextBlock Text="&#x1F3A4;" FontSize="14" Foreground="White"/>
            </Button>

            <!-- Whisper Undo Button (replace Gemini text with raw Whisper text) -->
            <Button x:Name="BtnWhisperUndo"
                    Style="{StaticResource RoundButton}"
                    Background="#2D2D2D"
                    Margin="0,8,0,0"
                    Click="BtnWhisperUndo_Click"
                    ToolTip="Gemini-Text durch Whisper-Rohtext ersetzen">
                <TextBlock Text="W" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

            <!-- Gemini Toggle Button -->
            <Button x:Name="BtnGemini"
                    Style="{StaticResource RoundButton}"
                    Background="#2D2D2D"
                    Margin="0,8,0,0"
                    Click="BtnGemini_Click"
                    ToolTip="Gemini an/aus">
                <TextBlock Text="G" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

            <!-- Auto-Enter Toggle Button -->
            <Button x:Name="BtnAutoEnter"
                    Style="{StaticResource RoundButton}"
                    Background="#2D2D2D"
                    Margin="0,8,0,0"
                    Click="BtnAutoEnter_Click"
                    ToolTip="Auto-Enter an/aus">
                <TextBlock Text="⏎" FontWeight="Bold" FontSize="16" Foreground="White"/>
            </Button>

        </StackPanel>
    </Border>
</Window>
